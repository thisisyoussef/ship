---
variables:
  primary_language: "Primary programming language"
  lint_cmd: "Command to run the linter"
  test_cmd: "Command to run tests"
  build_cmd: "Command to build the project"
  node_version: "(Optional) Node.js version for JS/TS projects"
  go_version: "(Optional) Go version for Go projects"
  python_version: "(Optional) Python version for Python projects"
---

name: Agent Lint

on:
  pull_request:
    branches: [main, master]

concurrency:
  group: agent-lint-${{ github.event.pull_request.number }}
  cancel-in-progress: true

jobs:
  lint:
    name: Lint
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

{{#node_version}}
      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "{{node_version}}"
          cache: npm

      - name: Install dependencies
        run: npm ci
{{/node_version}}

{{#go_version}}
      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version: "{{go_version}}"
{{/go_version}}

{{#python_version}}
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "{{python_version}}"

      - name: Install dependencies
        run: pip install -r requirements.txt
{{/python_version}}

      - name: Lint
        run: {{lint_cmd}}

  build:
    name: Build
    needs: lint
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

{{#node_version}}
      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "{{node_version}}"
          cache: npm

      - name: Install dependencies
        run: npm ci
{{/node_version}}

{{#go_version}}
      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version: "{{go_version}}"
{{/go_version}}

{{#python_version}}
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "{{python_version}}"

      - name: Install dependencies
        run: pip install -r requirements.txt
{{/python_version}}

      - name: Build
        run: {{build_cmd}}

  test:
    name: Test
    needs: build
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

{{#node_version}}
      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "{{node_version}}"
          cache: npm

      - name: Install dependencies
        run: npm ci
{{/node_version}}

{{#go_version}}
      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version: "{{go_version}}"
{{/go_version}}

{{#python_version}}
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "{{python_version}}"

      - name: Install dependencies
        run: pip install -r requirements.txt
{{/python_version}}

      - name: Test
        run: {{test_cmd}}

  verify-harness:
    name: Verify Harness
    needs: lint
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Run verify-harness.sh
        run: |
          if [ -f scripts/verify-harness.sh ]; then
            bash scripts/verify-harness.sh
          else
            echo "verify-harness.sh not found — skipping."
          fi

      - name: Verify ARCHITECTURE.md modules
        run: |
          echo "Checking that modules listed in ARCHITECTURE.md match actual directories..."
          if [ ! -f ARCHITECTURE.md ]; then
            echo "ARCHITECTURE.md not found — skipping module verification."
            exit 0
          fi
          errors=0
          # Extract paths from the Module Map table (column 2, skipping header and separator)
          paths=$(awk '/^\| Module/,/^$/' ARCHITECTURE.md \
            | grep '^|' \
            | tail -n +3 \
            | awk -F'|' '{gsub(/^ *`|` *$/, "", $3); print $3}' \
            | sed 's/^ *//;s/ *$//')
          for mod_path in $paths; do
            if [ -n "$mod_path" ] && [ ! -d "$mod_path" ] && [ ! -f "$mod_path" ]; then
              echo "ERROR: Module path '$mod_path' listed in ARCHITECTURE.md does not exist."
              errors=$((errors + 1))
            fi
          done
          if [ "$errors" -gt 0 ]; then
            echo "$errors module path(s) in ARCHITECTURE.md do not match actual directories."
            exit 1
          fi
          echo "All module paths verified."
