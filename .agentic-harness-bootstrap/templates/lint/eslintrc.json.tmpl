---
variables:
  uses_typescript: "Boolean — whether TypeScript is used"
  is_react: "Boolean — whether React is used"
  is_next: "Boolean — whether Next.js is used"
---

// .eslintrc.cjs — Strict ESLint configuration
// Strict settings catch the issues agents most commonly introduce:
//   - implicit `any` types that bypass the type system
//   - disordered imports that cause merge conflicts
//   - unused variables left behind after refactors

module.exports = {
  root: true,
  env: {
    es2024: true,
    node: true,
    browser: true,
  },
  extends: [
    "eslint:recommended",
{{#uses_typescript}}
    "plugin:@typescript-eslint/strict-type-checked",
{{/uses_typescript}}
{{#is_react}}
    "plugin:react/recommended",
    "plugin:react-hooks/recommended",
{{/is_react}}
{{#is_next}}
    "next/core-web-vitals",
{{/is_next}}
  ],
{{#uses_typescript}}
  parser: "@typescript-eslint/parser",
  parserOptions: {
    ecmaVersion: "latest",
    sourceType: "module",
    project: true,
  },
{{/uses_typescript}}
{{^uses_typescript}}
  parserOptions: {
    ecmaVersion: "latest",
    sourceType: "module",
  },
{{/uses_typescript}}
  plugins: [
    "import",
{{#uses_typescript}}
    "@typescript-eslint",
{{/uses_typescript}}
{{#is_react}}
    "react",
    "react-hooks",
{{/is_react}}
  ],
  rules: {
    // Errors, not warnings
{{#uses_typescript}}
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": ["error", {
      argsIgnorePattern: "^_",
      varsIgnorePattern: "^_",
    }],
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/no-unsafe-assignment": "error",
    "@typescript-eslint/no-unsafe-call": "error",
    "@typescript-eslint/no-unsafe-member-access": "error",
    "@typescript-eslint/no-unsafe-return": "error",
{{/uses_typescript}}
{{^uses_typescript}}
    "no-unused-vars": ["error", {
      argsIgnorePattern: "^_",
      varsIgnorePattern: "^_",
    }],
{{/uses_typescript}}

    // Import ordering
    "import/order": ["error", {
      groups: [
        "builtin",
        "external",
        "internal",
        "parent",
        "sibling",
        "index",
      ],
      "newlines-between": "always",
      alphabetize: { order: "asc", caseInsensitive: true },
    }],
    "import/no-duplicates": "error",

    // General strictness
    "no-console": "warn",
    eqeqeq: ["error", "always"],
    "no-var": "error",
    "prefer-const": "error",
  },
};
