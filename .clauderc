{
  "workspace": {
    "root": ".",
    "sourceDir": ".",
    "testDir": "e2e",
    "docsDir": "docs"
  },
  "rules": {
    "alwaysReadFirst": [
      "AGENTS.md",
      "docs/CONTEXT.md",
      "docs/IMPLEMENTATION_STRATEGY.md",
      "docs/user-stories/README.md"
    ],
    "beforeCoding": [
      "Use AGENTS.md as the primary rulebook.",
      "Use docs/user-stories/README.md as the master queue and open the active story file before edits.",
      "Do a preparation pass before implementation: read relevant code, contracts, and local docs first.",
      "Use docs/plans/ for design and technical planning, and docs/submissions/ for final bundles only.",
      "Use TDD for behavior changes and record validation, deployment status, and checkpoint evidence in the active story.",
      "Run bash scripts/check_ai_wiring.sh when the harness contract changes.",
      "Keep docs/CONTEXT.md current when live environment truth changes.",
      "Use .claude/CLAUDE.md only as a secondary appendix for Ship commands and architecture notes."
    ],
    "beforeHandoff": [
      "Verify the active story satisfies docs/DEFINITION_OF_DONE.md.",
      "Include exact user-facing verification steps and explicit deployment status in the handoff."
    ]
  }
}
