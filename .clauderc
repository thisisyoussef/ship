{
  "workspace": {
    "root": ".",
    "sourceDir": ".",
    "testDir": "e2e",
    "docsDir": ".ai/docs"
  },
  "rules": {
    "alwaysReadFirst": [
      ".ai/docs/SINGLE_SOURCE_OF_TRUTH.md",
      ".ai/agents/claude.md"
    ],
    "beforeCoding": [
      "If project setup is incomplete, choose the stack based on product needs before implementation",
      "Record the chosen language, framework, package manager, source directories, test directories, deployment target, and validation commands during setup",
      "Read .ai/docs/AGENTIC_ENGINEERING_PRINCIPLES.md",
      "Check .ai/memory/project/patterns.md for prior solutions",
      "Check .ai/memory/project/anti-patterns.md for mistakes to avoid",
      "Search .ai/docs/references/ for relevant documentation",
      "For feature stories, run .ai/workflows/spec-driven-delivery.md, review .ai/docs/research/spec-driven-tdd-playbook.md and .ai/docs/design/DESIGN_PHILOSOPHY_AND_LANGUAGE.md (for UI scope), and use .ai/templates/spec/ artifacts before writing tests/code",
      "If UI is in scope, apply .ai/skills/frontend-design.md and translate visual intent into concrete typography, spacing, color, depth, and motion constraints",
      "If UI direction is strategic, reusable, or multi-step, create a .ai/templates/spec/UI_PROMPT_BRIEF_TEMPLATE.md artifact using WIRE or WIRE+FRAME structure before implementation",
      "Run .ai/workflows/parallel-flight.md and claim a flight slot before implementation edits (default single mode)",
      "Run .ai/workflows/story-lookup.md for local + external best-practice lookup before implementation",
      "If the story changes prompts, retrieval, tools, routing, graders, or other AI behavior, run .ai/workflows/eval-driven-development.md and define objective, dataset, metrics, thresholds, and regression plan before implementation",
      "Use explicit completion criteria and avoid ending early when checks are unresolved",
      "For discovery/review tasks, avoid outcome-biased phrasing; request evidence and severity/risk first"
    ],
    "beforeHandoff": [
      "Run .ai/workflows/git-finalization.md and ensure scripts/git_finalize_guard.sh passes"
    ],
    "tdd": {
      "required": true,
      "testFirst": true,
      "coverageTarget": 90
    },
    "codeStandards": {
      "maxFileLines": 250,
      "targetFileLines": 150,
      "maxFunctionLines": 30,
      "targetFunctionLines": 15,
      "requireTypeHints": true,
      "requireDocstrings": true
    },
    "security": {
      "noHardcodedSecrets": true,
      "validateAllInput": true,
      "checkBeforeCommit": true
    }
  },
  "agents": {
    "tdd": ".ai/agents/tdd-agent.md",
    "architect": ".ai/agents/architect-agent.md",
    "security": ".ai/agents/security-agent.md",
    "deployment": ".ai/agents/deployment-agent.md"
  },
  "workflows": {
    "feature": ".ai/workflows/feature-development.md",
    "bugfix": ".ai/workflows/bug-fixing.md",
    "performance": ".ai/workflows/performance-optimization.md",
    "security": ".ai/workflows/security-review.md",
    "deployment": ".ai/workflows/deployment-setup.md",
    "specDriven": ".ai/workflows/spec-driven-delivery.md",
    "gitFinalization": ".ai/workflows/git-finalization.md",
    "parallelFlight": ".ai/workflows/parallel-flight.md",
    "evalDriven": ".ai/workflows/eval-driven-development.md",
    "aiArchitecture": ".ai/workflows/ai-architecture-change.md",
    "lookup": ".ai/workflows/story-lookup.md"
  },
  "skills": {
    "frontendDesign": ".ai/skills/frontend-design.md"
  },
  "memory": {
    "session": ".ai/memory/session/",
    "project": ".ai/memory/project/",
    "codex": ".ai/memory/codex/"
  }
}
